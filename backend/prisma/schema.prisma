generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String                  @id @default(cuid())
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  fullName                 String?
  email                    String                  @unique
  password                 String
  avatar                   String                  @default("/default-avatar.png")
  bio                      String?
  publicKey                String?
  emailVerified            Boolean                 @default(false)
  role                     Role                    @default(user)
  isActive                 Boolean                 @default(true)
  verificationCode         String?
  verificationCodeExpires  DateTime?
  tokenVersion             Int                     @default(0)
  reportsReceivedCount     Int                     @default(0)
  isPermanentlyDeleted     Boolean                 @default(false)
  accountStatus            AccountStatus           @default(ACTIVE)
  suspendedUntil           DateTime?
  suspendedReason          String?
  bannedAt                 DateTime?
  bannedReason             String?
  strikeCount              Int                     @default(0)
  lastStrikeAt             DateTime?
  profileVerified          Boolean                 @default(false)
  photoVerified            Boolean                 @default(false)
  verifiedAt               DateTime?
  rateLimits               Json?
  collegeName              String?
  collegeSlug              String?
  religionKey              String?
  notificationPrefs        Json?
  privacyPrefs             Json?
  pushTokens               String[]
  twoFactorEnabled         Boolean                 @default(false)
  twoFactorSecret          String?
  twoFactorBackupCodes     String[]
  hasDatingProfile         Boolean                 @default(false)
  e2eeBackup               Json?
  e2eeBundleUpdatedAt      DateTime?
  e2eeBundleVersion        Int                     @default(1)
  e2eeOneTimePrekeys       Json?
  e2eeSignedPrekey         String?
  e2eeSignedPrekeySig      String?
  verificationCodeAttempts Int                     @default(0)
  resetToken               String?
  resetTokenExpires        DateTime?
  appeals                  Appeal[]
  datingProfile            DatingProfile?
  directMessagesFrom       DirectMessage[]         @relation("DMFrom")
  directMessagesTo         DirectMessage[]         @relation("DMTo")
  dmReactions              DirectMessageReaction[]
  memberships              Member[]
  messages                 Message[]               @relation("UserMessages")
  moderationLogs           ModerationLog[]         @relation("ModeratorActions")
  photoReports             PhotoReport[]           @relation("PhotoReporter")
  reactions                Reaction[]
  reportsAgainst           Report[]                @relation("Reported")
  reportsMade              Report[]                @relation("Reporter")
  strikes                  Strike[]
  trustedDevices           TrustedDevice[]
  verificationRequests     VerificationRequest[]

  @@map("users")
}

model College {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String    @unique
  key          String    @unique
  emailDomains String[]
  communityId  String
  community    Community @relation(fields: [communityId], references: [id])

  @@index([emailDomains])
  @@map("colleges")
}

model Community {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  name        String
  type        CommunityType @default(custom)
  key         String?
  slug        String?       @unique
  description String?
  isPrivate   Boolean       @default(false)
  tags        String[]
  imageUrl    String?
  createdBy   String?
  colleges    College[]
  members     Member[]
  messages    Message[]

  @@index([type, key])
  @@map("communities")
}

model Member {
  id           String       @id @default(cuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String
  communityId  String
  name         String
  avatar       String       @default("/default-avatar.png")
  role         MemberRole   @default(member)
  memberStatus MemberStatus @default(active)
  fcmToken     String?
  community    Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([userId, memberStatus])
  @@index([communityId, memberStatus])
  @@map("members")
}

model Message {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  content         String
  attachments     Json?
  clientMessageId String?
  status          MessageStatus @default(sent)
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  editedAt        DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  senderName      String
  senderAvatar    String        @default("/default-avatar.png")
  senderId        String
  communityId     String
  replyToId       String?
  replyToSnapshot Json?
  community       Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  replyTo         Message?      @relation("ReplyTo", fields: [replyToId], references: [id])
  replies         Message[]     @relation("ReplyTo")
  sender          User          @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)
  reactions       Reaction[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

model Reaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  emoji     String
  messageId String
  userId    String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reactions")
}

model DirectMessage {
  id                 String                  @id @default(cuid())
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  content            String?
  type               DMType                  @default(text)
  context            String                  @default("community")
  attachments        Json?
  isEncrypted        Boolean                 @default(false)
  status             MessageStatus           @default(sent)
  isDeleted          Boolean                 @default(false)
  deletedAt          DateTime?
  editedAt           DateTime?
  deliveredAt        DateTime?
  readAt             DateTime?
  fromId             String
  toId               String
  recipientPublicKey String?
  senderPublicKey    String?
  from               User                    @relation("DMFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to                 User                    @relation("DMTo", fields: [toId], references: [id], onDelete: Cascade)
  reactions          DirectMessageReaction[]

  @@index([fromId, toId, createdAt])
  @@index([toId, status])
  @@map("direct_messages")
}

model DirectMessageReaction {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  emoji     String
  dmId      String
  userId    String
  dm        DirectMessage @relation(fields: [dmId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dm_reactions")
}

model DatingProfile {
  id                String            @id @default(cuid())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  userId            String            @unique
  firstName         String
  birthDate         DateTime
  gender            Gender
  bio               String?           @db.VarChar(500)
  height            Int?
  collegeSlug       String
  major             String?
  year              StudyYear?
  lookingFor        LookingFor[]
  hobbies           String[]
  instagramHandle   String?
  latitude          Float?
  longitude         Float?
  isProfileVisible  Boolean           @default(true)
  isPaused          Boolean           @default(false)
  isPhotoVerified   Boolean           @default(false)
  photoVerifiedAt   DateTime?
  approvalStatus    ApprovalStatus    @default(PENDING)
  rejectionReason   String?
  score             Float             @default(0)
  gradYear          String?
  greekLife         String?
  interests         String[]
  prompts           Json?
  spotifyTopArtists String[]
  blocksReceived    DatingBlock[]     @relation("Blocked")
  blocksGiven       DatingBlock[]     @relation("Blocker")
  matches1          DatingMatch[]     @relation("MatchProfile1")
  matches2          DatingMatch[]     @relation("MatchProfile2")
  photos            DatingPhoto[]
  preference        DatingPreference?
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  swipesMade        DatingSwipe[]     @relation("Swiper")
  swipesReceived    DatingSwipe[]     @relation("Target")

  @@index([collegeSlug])
  @@index([gender])
  @@index([userId])
  @@map("dating_profiles")
}

model DatingPreference {
  id                       String        @id @default(cuid())
  datingProfileId          String        @unique
  ageMin                   Int           @default(18)
  ageMax                   Int           @default(30)
  maxDistance              Int           @default(50)
  interestedInGender       Gender[]
  preferredColleges        String[]
  showToPeopleOnCampusOnly Boolean       @default(false)
  isDistanceVisible        Boolean       @default(true)
  isCollegeVisible         Boolean       @default(true)
  datingProfile            DatingProfile @relation(fields: [datingProfileId], references: [id], onDelete: Cascade)

  @@map("dating_preferences")
}

model DatingPhoto {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  datingProfileId String
  url             String
  thumbnail       String?
  order           Int           @default(0)
  status          PhotoStatus   @default(PENDING)
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  aiFlags         Json?
  isMain          Boolean       @default(false)
  datingProfile   DatingProfile @relation(fields: [datingProfileId], references: [id], onDelete: Cascade)
  reports         PhotoReport[]

  @@index([datingProfileId])
  @@index([status])
  @@map("dating_photos")
}

model DatingSwipe {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  swiperId  String
  targetId  String
  type      SwipeType
  swiper    DatingProfile @relation("Swiper", fields: [swiperId], references: [id], onDelete: Cascade)
  target    DatingProfile @relation("Target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([swiperId, targetId])
  @@index([swiperId])
  @@index([targetId])
  @@map("dating_swipes")
}

model DatingMatch {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  profile1Id  String
  profile2Id  String
  isActive    Boolean       @default(true)
  unmatchedBy String?
  channelId   String?
  profile1    DatingProfile @relation("MatchProfile1", fields: [profile1Id], references: [id], onDelete: Cascade)
  profile2    DatingProfile @relation("MatchProfile2", fields: [profile2Id], references: [id], onDelete: Cascade)

  @@unique([profile1Id, profile2Id])
  @@index([profile1Id])
  @@index([profile2Id])
  @@map("dating_matches")
}

model Report {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  reporterId  String
  reportedId  String
  reason      ReportReason
  category    String?
  details     String?
  targetType  String
  targetId    String?
  screenshots String[]
  status      ReportStatus   @default(PENDING)
  priority    ReportPriority @default(NORMAL)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  actionTaken String?
  reported    User           @relation("Reported", fields: [reportedId], references: [id])
  reporter    User           @relation("Reporter", fields: [reporterId], references: [id])

  @@index([reportedId, status])
  @@index([status, priority])
  @@index([createdAt])
  @@map("reports")
}

model DatingBlock {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  blockerId String
  blockedId String
  blocked   DatingProfile @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   DatingProfile @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("dating_blocks")
}

model VerificationRequest {
  id         String           @id @default(cuid())
  userId     String
  poseId     String
  photoUrl   String
  status     ApprovalStatus   @default(PENDING)
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  pose       VerificationPose @relation(fields: [poseId], references: [id])
  user       User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("verification_requests")
}

model VerificationPose {
  id                String                @id @default(cuid())
  name              String
  instruction       String
  referenceImageUrl String
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  requests          VerificationRequest[]

  @@map("verification_poses")
}

model PhotoReport {
  id         String            @id @default(cuid())
  createdAt  DateTime          @default(now())
  reporterId String
  photoId    String
  reason     PhotoReportReason
  details    String?
  status     ReportStatus      @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  photo      DatingPhoto       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  reporter   User              @relation("PhotoReporter", fields: [reporterId], references: [id])

  @@index([photoId, status])
  @@map("photo_reports")
}

model Strike {
  id        String         @id @default(cuid())
  createdAt DateTime       @default(now())
  userId    String
  reason    String
  severity  StrikeSeverity @default(MINOR)
  details   String?
  reportId  String?
  issuedBy  String
  expiresAt DateTime?
  active    Boolean        @default(true)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([createdAt])
  @@map("strikes")
}

model Appeal {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  type        AppealType
  strikeId    String?
  reportId    String?
  reason      String
  status      AppealStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  decision    String?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
  @@map("appeals")
}

model ModerationLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  action      String
  targetType  String
  targetId    String
  moderatorId String
  reason      String?
  details     Json?
  userId      String?
  reportId    String?
  strikeId    String?
  moderator   User     @relation("ModeratorActions", fields: [moderatorId], references: [id])

  @@index([targetType, targetId])
  @@index([moderatorId])
  @@index([createdAt])
  @@map("moderation_logs")
}

model TrustedDevice {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String
  deviceModel String?
  ipAddress   String?
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("trusted_devices")
}

enum Role {
  user
  mod
  admin
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  UNDER_REVIEW
  DEACTIVATED
}

enum CommunityType {
  college
  religion
  custom
}

enum MemberRole {
  member
  admin
  owner
}

enum MemberStatus {
  active
  invited
  banned
  online
  owner
}

enum MessageStatus {
  sent
  delivered
  read
  edited
  deleted
}

enum DMType {
  text
  photo
  video
  audio
  file
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
}

enum LookingFor {
  RELATIONSHIP
  CASUAL
  FRIENDS
  UNSURE
}

enum StudyYear {
  FRESHMAN
  SOPHOMORE
  JUNIOR
  SENIOR
  GRADUATE
  ALUMNI
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SwipeType {
  LIKE
  DISLIKE
  SUPERLIKE
}

enum ReportReason {
  HARASSMENT
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  SAFETY_CONCERN
  SPAM
  UNDERAGE
  HATE_SPEECH
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PhotoReportReason {
  NUDITY
  NOT_REAL_PERSON
  SOMEONE_ELSE
  INAPPROPRIATE
  CELEBRITY_STOCK
  OTHER
}

enum StrikeSeverity {
  MINOR
  MODERATE
  SEVERE
}

enum AppealType {
  STRIKE
  SUSPENSION
  BAN
  PHOTO_REJECTION
}

enum AppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  DENIED
}
